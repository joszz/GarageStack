# Copy this file to .env and fill in real values - never commit .env

# ── SAIC / MG iSMART ────────────────────────────────────────────────────────
# Must be the vehicle owner account. Shared/secondary accounts lack the write
# permissions required to register alarm switches and will get error 1100003.
# Use a separate account for the MG iSmart phone app to avoid session conflicts.
SAIC_USER=your_mg_account@example.com
SAIC_PASSWORD=your_mg_account_password
# Region the car is registered in. eu | cn | row
SAIC_REGION=eu

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# To use your own existing Postgres server set POSTGRES_HOST to its address and
# remove (or don't start) the bundled postgres profile:
#   docker compose up                        <- external postgres
#   docker compose --profile bundled-postgres up   <- bundled postgres
#
# The bundled service creates the database automatically; on an external server
# you must create the database and user yourself first.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=garagestack
POSTGRES_USER=garagestack
POSTGRES_PASSWORD=changeme_use_something_strong

# ── MQTT ────────────────────────────────────────────────────────────────────
# Defaults to the bundled Mosquitto broker running inside Docker Compose.
# Set MQTT_HOST / MQTT_PORT to point at your own broker instead.
MQTT_HOST=mosquitto
MQTT_PORT=1883
# Host port Mosquitto is published on (only relevant for the bundled broker).
MQTT_EXTERNAL_PORT=1883

# ── Ports ───────────────────────────────────────────────────────────────────
# Host port for the frontend (nginx). Use 8080 by default to avoid clashing
# with existing reverse proxies/web servers that already bind port 80.
FRONTEND_PORT=8080
# Host port for the API (only needed if you access the API directly;
# the frontend proxies /api requests internally and does not need this open).
API_PORT=5000

# ── CORS ────────────────────────────────────────────────────────────────────
# The URL your browser uses to reach the frontend - must match exactly.
# Add more origins by setting Cors__Origins__1 etc. directly in docker-compose.
CORS_ORIGIN=http://localhost

# ── API Authentication ───────────────────────────────────────────────────────
# Required for issuing login JWT tokens. Use at least 32 random bytes.
# Generate with OpenSSL: openssl rand -base64 32
# PowerShell alternative: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
JWT_SECRET=

# ── Logging ──────────────────────────────────────────────────────────────────
# Set to true to enable Debug-level logs (api + worker). Useful when diagnosing
# MQTT mapping gaps or unexpected behaviour. Keep false in production.
DEBUG_LOGS=false

# ── VAPID (push notifications) ───────────────────────────────────────────────
# Generate once with: npx web-push generate-vapid-keys
# Leave blank to disable push notifications (the app still works without them).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Homepage widget ───────────────────────────────────────────────────────────
# Static API key for the unauthenticated /api/widget/{vin}/status endpoint used
# by the gethomepage.dev Custom API widget. Leave empty to disable the endpoint.
# Generate with: openssl rand -base64 32
WIDGET_API_KEY=
